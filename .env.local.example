# Supabase — https://supabase.com/dashboard/project/<id>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://<project-id>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>   # 절대 NEXT_PUBLIC_ 붙이지 말 것

# Google Maps — https://console.cloud.google.com/apis/credentials
# API key restrictions: HTTP referrer → 본인 Vercel 도메인만
# API restrictions: Maps JavaScript API + Places API (New)만 허용
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=<maps-api-key>

# Google Maps Server Key — Routes API 전용 (서버에서만 사용)
# API restrictions: Routes API만 허용
GOOGLE_MAPS_SERVER_KEY=<server-maps-api-key>
